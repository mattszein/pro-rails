# .env — one per worktree on the homelab
# On local dev (single worktree), no .env needed — defaults just work.

# Required per worktree
COMPOSE_PROJECT_NAME=pro-rails-feat-billing
DB_NAME_PREFIX=pro_rails_feat_billing
REDIS_URL=redis://redis:6379/2
APP_HOST=pro-rails-feat-billing.homelab

# Homelab: bare metal services (uncomment if not using docker-compose.infra.yml)
# DB_HOST=host.docker.internal
# DB_USERNAME=postgres
# DB_PASSWORD=postgres
# DB_PORT=5432
# REDIS_URL=redis://host.docker.internal:6379/2
