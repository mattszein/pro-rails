# .env — worktree
COMPOSE_PROJECT_NAME=pro-rails-feat-billing

RAILS_PORT=3020
WS_PORT=8180
WS_BROADCAST_PORT=8190
MAILDEV_SMTP_PORT=1026
MAILDEV_WEB_PORT=8026
CHROME_PORT=3334

# DB apunta al baremetal via host gateway
DB_HOST=host.docker.internal
DB_NAME_PREFIX=pro_rails_feat_billing
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_PORT=5432

# Valkey baremetal, DB number distinto por worktree
REDIS_URL=redis://host.docker.internal:6379/2
