<%= render Settings::LayoutComponent.new(active_section: :appearance) do %>
  <%= render Core::CardComponent.new do %>
    <div class="text-center mb-6">
      <h1><%= t("settings.font_theme_title") %></h1>
      <p><%= t("settings.font_theme_subtitle") %></p>
    </div>
    <%= render Settings::FontComponent.new(current_font: "default") %>
    <%= render Settings::ThemePickerComponent.new(current_theme: "default") %>
  <% end %>
<% end %>
