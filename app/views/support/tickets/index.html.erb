<div class="w-full">
  <div class="flex justify-between items-center pb-2">
    <h1 class="text-xl font-semibold"><%= t("support.tickets.title") %></h1>
    <%= render(Core::LinkComponent.new(name: t("support.tickets.add_ticket"), url: new_support_ticket_path, style: :as_button, theme: :create, size: :sm, html_options: {data: {turbo_frame: "modal"}})) %>
  </div>
  <%= turbo_stream_from "tickets" %>
  <%= render Core::CardComponent.new(padding: :none) do %>
    <div class="flex p-4 gap-4">
      <%= render Core::TableComponent.new(
            rows: @tickets,
            columns: [
              {label: t("views.labels.title")},
              {label: t("views.labels.category")},
              {label: t("views.labels.description")},
              {label: t("views.labels.status")},
              {label: t("views.shared.actions")}
            ],
            options: {ids: {tbody: "tickets"}}
          ) do %>
        <% @tickets.each_with_index do |ticket, index| %>
          <%= render "ticket_table", ticket: ticket, index: index %>
        <% end %>
      <% end %>
    </div>
  <% end %>
</div>
