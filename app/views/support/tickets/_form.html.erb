<%= form_with(model: ticket, url: ticket.persisted? ? support_ticket_path(ticket) : support_tickets_path, builder: CustomFormBuilder, multipart: true, data: {turbo: true}) do |form| %>
  <% if ticket.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-lg mt-3">
      <h2><%= pluralize(ticket.errors.count, "error") %> prohibited this ticket from being saved:</h2>

      <ul>
        <% ticket.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>
    <%= form.text_field :title, {autofocus: true, required: true, placeholder: " ", autocomplete: "title", label: t("views.labels.title"), class: "w-full"} %>
    <div class="mt-6">
      <%= form.label :category, class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.select :category,
            options_for_select(Support::Ticket.categories.keys.map { |cat| [t("enums.ticket.category.#{cat}"), cat] }, ticket.persisted? ? ticket.category : nil),
            {include_blank: t("support.tickets.select_category")},
            {required: true, class: "w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500"} %>
    </div>
    <div class="mt-6">
    <%= form.label :description, class: "sr-only" %>
    <%= form.text_area :description, rows: 4, placeholder: t("support.tickets.description_placeholder"), class: "w-full mt-4" %>
    </div>
    <% unless ticket.persisted? %>
      <div class="mt-6">
        <%= form.file_field :attachments,
              multiple: true,
              accept: FileUploadConfig.allowed_content_types_list.join(","),
              label: t("support.tickets.attach_files_label"),
              helper_text: t("support.tickets.upload_limit", max_files: FileUploadConfig.max_files_per_ticket),
              icon: "plus" %>
      </div>
    <% end %>
  <div class="mt-6">
    <%= form.button t("views.shared.save"), {theme: :create, fullw: true} %>
  </div>
<% end %>
