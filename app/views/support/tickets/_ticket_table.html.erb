<tr id="<%= ActionView::RecordIdentifier.dom_id(ticket) %>">
  <%= render Core::TableCellComponent.new do %>
    <%= ticket.title %>
  <% end %>

  <%= render Core::TableCellComponent.new do %>
    <%= t("enums.ticket.category.#{ticket.category}") %>
  <% end %>

  <%= render Core::TableCellComponent.new do %>
    <%= ticket.description %>
  <% end %>

  <%= render Core::TableCellComponent.new do %>
    <%= render(Core::BadgeComponent.new(label: ticket.status, theme: ticket_status_theme(ticket.status))) %>
  <% end %>

  <%= render Core::TableCellComponent.new do %>
    <%= render(Core::LinkComponent.new(name: t("views.shared.show"), url: support_ticket_path(ticket), style: :as_button, theme: :show, size: :xs)) %>
    <%= render(Core::LinkComponent.new(name: t("views.shared.edit"), url: edit_support_ticket_path(ticket), style: :as_button, theme: :edit, size: :xs, html_options: {data: {turbo_frame: "modal"}})) %>
  <% end %>
</tr>
