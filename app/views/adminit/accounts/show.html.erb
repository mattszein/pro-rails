<div class="md:flex items-center justify-between mb-4">
  <h1 class="text-xl">
    <%= link_to t("adminit.navigation.accounts"), adminit_accounts_path, class: "text-indigo-500" %>
  </h1>
</div>

<div class="flex flex-col gap-6">
<%= render(Core::CardComponent.new(padding: :sm)) do %>
<dl class="dark:divide-gray-700 text-left grid grid-cols-3 gap-4">
    <div>
        <dt class="md:text-md"><%= t("shared.labels.id") %></dt>
        <dd class="text-md font-semibold"><%= @account.id %></dd>
    </div>
    <div>
        <dt class="md:text-md"><%= t("shared.labels.name") %></dt>
        <dd class="text-md font-semibold"><%= @account.email %></dd>
    </div>
</dl>
<% end %>
