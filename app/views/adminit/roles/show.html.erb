<div class="md:flex items-center justify-between mb-4">
  <h1 class="text-xl">
    <%= link_to t("adminit.navigation.roles"), adminit_roles_path, class: "text-indigo-500" %>
  </h1>

  <div class="flex gap-2 items-center px-4">
    <%= link_to t("adminit.roles.add_role"), account_select_adminit_role_path(@role), data: {turbo_frame: "modal"}, class: "block bg-white hover:bg-gray-100 text-gray-800 font-semibold py-2 px-4 border border-gray-400 rounded shadow" %>
  </div>
</div>

<div class="flex flex-col gap-6">
<%= render(Core::CardComponent.new(padding: :sm)) do %>
<dl class="text-gray-900 dark:text-white dark:divide-gray-700 text-left grid grid-cols-3 gap-4">
    <div>
        <dt class="text-gray-500 md:text-md dark:text-gray-400"><%= t("shared.labels.id") %></dt>
        <dd class="text-md font-semibold"><%= @role.id %></dd>
    </div>
    <div>
        <dt class="text-gray-500 md:text-md dark:text-gray-400"><%= t("shared.labels.name") %></dt>
        <dd class="text-md font-semibold"><%= @role.name %></dd>
    </div>
    <div>
        <dt class="text-gray-500 md:text-md dark:text-gray-400"><%= t("adminit.navigation.accounts") %></dt>
        <dd class="text-md font-semibold"><%= @role.accounts.length %></dd>
    </div>
</dl>
<% end %>

<%= render(Core::CardComponent.new(padding: :sm)) do %>
   <table class="w-full text-sm text-left rtl:text-right text-gray-500 dark:text-gray-400">
        <thead class="text-sm text-gray-700 uppercase bg-gray-50 dark:bg-gray-700 dark:text-gray-400">
            <tr>
                <th scope="col" class="px-6 py-3">
                  <%= t("shared.labels.email") %>
                </th>
                <th scope="col" class="px-6 py-3">
                  <%= t("shared.common.actions") %>
                </th>
            </tr>
        </thead>
        <tbody>
          <%= render partial: "role_accounts", collection: @role.accounts, as: :account %>
        </tbody>
    </table>
<% end %>
<div>
