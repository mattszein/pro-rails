<div class="w-full">
  <div class="flex justify-between items-center pb-2">
    <%= link_to t("adminit.roles.back_to_roles"), adminit_roles_path, class: "text-indigo-500" %>
    <div class="flex gap-2 items-center px-4">
      <%= render(Core::LinkComponent.new(name: t("adminit.roles.add_member"), url: account_select_adminit_role_path(@role), style: :as_button, theme: :create, size: :sm, html_options: {data: {turbo_frame: "modal"}})) %>
    </div>
  </div>

  <div class="space-y-4">
    <%= render(Core::CardComponent.new(classes: "space-y-4")) do %>
      <div class="flex items-center gap-4">
        <h1 class="text-xl font-bold"><%= Role.model_name.human %>: <%= @role.name %></h1>
        <% if @role.superadmin? %>
          <%= render(Core::BadgeComponent.new(label: t("adminit.roles.superadmin"), theme: :primary, size: :md)) %>
        <% end %>
      </div>

      <%= render Core::BoxComponent.new do %>
        <%= render Core::DefinitionListComponent.new(variant: :info, gap: :sm) do |dl| %>
          <% dl.with_item(term: t("shared.labels.id")) do %>
            <%= @role.id %>
          <% end %>
          <% dl.with_item(term: t("shared.labels.name")) do %>
            <%= @role.name %>
          <% end %>
          <% dl.with_item(term: t("shared.labels.members")) do %>
            <%= @role.accounts.size %>
          <% end %>
        <% end %>
      <% end %>

      <% if @role.permissions.any? %>
        <div>
          <p class="text-sm font-semibold mb-2"><%= t("adminit.roles.permissions_label") %></p>
          <div class="flex flex-wrap gap-2">
            <% @role.permissions.each do |permission| %>
              <%= render(Core::BadgeComponent.new(label: permission.resource, theme: :secondary, size: :sm)) %>
            <% end %>
          </div>
        </div>
      <% end %>
    <% end %>

    <%= render Core::CardComponent.new do %>
      <div class="flex items-center justify-between p-4">
        <h2 class="font-semibold"><%= t("shared.labels.members") %></h2>
      </div>
      <% if @role.accounts.any? %>
        <div class="px-4 pb-4">
          <%= render Core::TableComponent.new(rows: @role.accounts, columns: role_member_columns(@role)) %>
        </div>
      <% else %>
        <p class="text-sm text-slate-500 italic px-4 pb-4"><%= t("adminit.roles.no_members") %></p>
      <% end %>
    <% end %>
  </div>
</div>
