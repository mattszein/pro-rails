<div id="<%= dom_id ticket, "admin" %>" class="space-y-4">
  <!-- Top Row: Info and Notes -->
  <div class="flex space-x-2">
    <%= render(Core::CardComponent.new(classes: "basis-1/2 flex flex-col overflow-y-auto space-y-4")) do %>
      <%= render Adminit::TicketInfoComponent.new(ticket: ticket) %>
      <h3 class="font-bold leading-tight">
        <%= ticket.title %>
      </h3>
      <p class="leading-relaxed">
        <%= ticket.description %>
      </p>
      <%= render Support::AttachmentsComponent.new(ticket: ticket, show_upload_form: false) %>
    <% end %>

    <%= render(Core::CardComponent.new(classes: "basis-1/2 flex flex-col overflow-hidden")) do %>
      <div class="flex flex-col h-full min-h-0">
        <div class="mb-4 shrink-0">
          <%= render Adminit::Tickets::NoteFormComponent.new(ticket: ticket) %>
        </div>
        <div class="flex-1 overflow-y-auto pr-2 space-y-3 scrollbar-thin scrollbar-thumb-slate-200 dark:scrollbar-thumb-slate-700 min-h-0">
          <% if @notes.any? %>
            <%= render Adminit::Tickets::NoteComponent.with_collection(@notes, as: :note) %>
          <% else %>
            <p class="text-sm text-slate-500 italic text-center py-4">No notes yet.</p>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Bottom Row: Conversation -->
  <div class="space-y-6">
    <%= render(Core::CardComponent.new(variant: :glass, glow: true, classes: "space-y-4")) do %>
      <%= render Support::ConversationComponent.new(
            conversation: @conversation,
            messages: @messages
          ) do %>
        <%= render "support/conversations/message_form", ticket: ticket %>
      <% end %>
    <% end %>
  </div>
</div>
