<%= render(Core::CardComponent.new(classes: "space-y-4")) do %>
  <p class="text-lg"><%= t("home.welcome") %></p>
  <div class="flex items-center space-x-3 justify-center">
    <%= render(Core::LinkComponent.new(name: t("shared.navigation.sign_in"), url: rodauth.login_path, style: :as_button, theme: :primary, size: :sm)) %>
    <%= render(Core::LinkComponent.new(name: t("shared.navigation.register"), url: rodauth.create_account_path, style: :as_button, theme: :secondary, size: :sm)) %>
  </div>
<% end %>
