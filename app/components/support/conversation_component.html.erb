<!-- Conversation Header -->
<div class="pb-6 border-b border-slate-200 dark:border-slate-700">
  <h3 class="text-xl font-semibold text-slate-800 dark:text-slate-200 flex items-center gap-2">
    <svg class="w-5 h-5 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8h1a4 4 0 010 8h-1m-15-8h1a4 4 0 000-8H3m6 8l4-4m0 0l4 4m-4-4v12"></path>
    </svg>
    <%= title %>
  </h3>
</div>
<!-- Messages Container -->
<div class="space-y-6 max-h-96 overflow-y-auto" id="<%= dom_id(conversation) %>_messages" data-controller="support--conversation-component" data-support--conversation-component-target="messages">
  <%= helpers.turbo_stream_from conversation %>
  <%= render(collection: messages, partial: "support/conversations/message") %>
</div>
<!-- Message Input Form  -->
<div id="message_form_container">
  <%= content %>
</div>
