<div class="mt-4 pt-4 border-t border-gray-200">
  <%= form_with(model: ticket, url: attach_files_support_ticket_path(@ticket), method: :post, builder: CustomFormBuilder, multipart: true, class: "space-y-4") do |form| %>
    <%= form.file_field :attachments,
          multiple: true,
          accept: allowed_types,
          label: t("support.attachments.select_files"),
          helper_text: t("support.attachments.upload_helper", max_files: max_files),
          icon: "plus" %>
    <div class="flex gap-2">
      <%= form.button t("support.attachments.upload_button"), {theme: :create, size: :sm} %>
    </div>
  <% end %>
</div>
