<div class="bg-blue-50 dark:bg-blue-900/20 p-4 rounded-xl border border-blue-200 dark:border-blue-800">
  <p class="text-blue-800 dark:text-blue-300 mb-4 font-medium">This ticket is marked as finished.</p>
  <p class="text-sm text-slate-600 dark:text-slate-400 mb-4">If your issue is not resolved, you can request to reopen it by providing a reason below.</p>
  <%= form_with url: helpers.request_reopen_support_ticket_path(ticket), class: "space-y-3" do |form| %>
    <%= form.text_area :reason, placeholder: "Reason for reopening...", rows: 2, required: true %>
    <div class="flex justify-end">
      <%= form.button "Request Reopen", {theme: :primary} %>
    </div>
  <% end %>
</div>
